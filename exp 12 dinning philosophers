#include <stdio.h>
#include <stdlib.h>
#include <pthread.h>
#include <unistd.h>

#define NUM_PHILOSOPHERS 5
#define NUM_CHOPSTICKS 5

pthread_mutex_t chopsticks[NUM_CHOPSTICKS];
pthread_t philosophers[NUM_PHILOSOPHERS];

void* philosopher_lifecycle(void* num) {
    int id = *(int*)num;

    while (1) {
        printf("Philosopher %d is thinking.\n", id);
        sleep(rand() % 3 + 1); // Simulate thinking

        printf("Philosopher %d is hungry.\n", id);

        // Deadlock Prevention: Asymmetric chopstick pickup
        if (id % 2 != 0) {
            // Odd philosophers: Left then Right
            pthread_mutex_lock(&chopsticks[id]);
            pthread_mutex_lock(&chopsticks[(id + 1) % NUM_CHOPSTICKS]);
        } else {
            // Even philosophers: Right then Left
            pthread_mutex_lock(&chopsticks[(id + 1) % NUM_CHOPSTICKS]);
            pthread_mutex_lock(&chopsticks[id]);
        }

        // Eating
        printf("Philosopher %d is EATING using chopsticks %d and %d.\n", 
               id, id, (id + 1) % NUM_CHOPSTICKS);
        sleep(rand() % 3 + 1); // Simulate eating

        // Put down chopsticks
        printf("Philosopher %d finished eating and put down chopsticks.\n", id);
        pthread_mutex_unlock(&chopsticks[id]);
        pthread_mutex_unlock(&chopsticks[(id + 1) % NUM_CHOPSTICKS]);
    }
    
    return NULL;
}

int main() {
    int i;
    int philosopher_ids[NUM_PHILOSOPHERS];

    // Seed the random number generator
    srand(time(NULL));

    // Initialize the mutexes (chopsticks)
    for (i = 0; i < NUM_CHOPSTICKS; i++) {
        if (pthread_mutex_init(&chopsticks[i], NULL) != 0) {
            printf("Mutex initialization failed\n");
            return 1;
        }
    }

    // Create the philosopher threads
    for (i = 0; i < NUM_PHILOSOPHERS; i++) {
        philosopher_ids[i] = i;
        if (pthread_create(&philosophers[i], NULL, philosopher_lifecycle, &philosopher_ids[i]) != 0) {
            printf("Thread creation failed\n");
            return 1;
        }
    }

    // Join the threads (Since the threads run infinitely, this keeps the main thread alive)
    for (i = 0; i < NUM_PHILOSOPHERS; i++) {
        pthread_join(philosophers[i], NULL);
    }

    // Destroy mutexes (unreachable in infinite loop, but good practice)
    for (i = 0; i < NUM_CHOPSTICKS; i++) {
        pthread_mutex_destroy(&chopsticks[i]);
    }

    return 0;
}
