#include <stdio.h>
#include <stdlib.h>
#include <fcntl.h>      // For fcntl() and open flags
#include <unistd.h>     // For lseek(), read(), write(), close()
#include <sys/stat.h>   // For stat() structures
#include <sys/types.h>  // For directory types
#include <dirent.h>     // For opendir() and readdir()
#include <string.h>

void demonstrate_directory_calls() {
    DIR *dir;
    struct dirent *entry;

    printf("\n--- 1 & 2. Demonstrating opendir() and readdir() ---\n");
    
    // Open the current working directory (".")
    dir = opendir(".");
    if (dir == NULL) {
        perror("Error opening directory");
        return;
    }
    printf("[SUCCESS] Directory '.' opened successfully.\n");

    // Read and list the first few contents of the directory
    printf("Directory Contents:\n");
    int count = 0;
    while ((entry = readdir(dir)) != NULL && count < 5) {
        printf(" -> %s (Type: %d)\n", entry->d_name, entry->d_type);
        count++;
    }

    // Close directory stream
    closedir(dir);
}

void demonstrate_stat_call(const char *filename) {
    struct stat file_stat;

    printf("\n--- 3. Demonstrating stat() ---\n");

    // Retrieve file metadata
    if (stat(filename, &file_stat) < 0) {
        perror("Error getting file stats");
        return;
    }

    // Print metadata metrics
    printf("File: %s\n", filename);
    printf(" -> Size: %ld bytes\n", file_stat.st_size);
    printf(" -> Number of Links: %ld\n", file_stat.st_nlink);
    printf(" -> File Permissions: %o\n", file_stat.st_mode & 0777);
    printf(" -> Inode Number: %ld\n", file_stat.st_ino);
}

void demonstrate_seek_and_fcntl() {
    int fd;
    char filename[] = "test_calls.txt";
    char write_data[] = "UNIX System Programming";
    char buffer[20];

    printf("\n--- 4 & 5. Demonstrating lseek() and fcntl() ---\n");

    // Setup: Create a file and populate it
    fd = open(filename, O_CREAT | O_RDWR | O_TRUNC, 0644);
    if (fd < 0) {
        perror("Error opening file");
        return;
    }
    write(fd, write_data, strlen(write_data));

    // A. Using lseek() to jump 5 bytes from the start
    // SEEK_SET means relative to the beginning of the file
    if (lseek(fd, 5, SEEK_SET) < 0) {
        perror("lseek error");
        close(fd);
        return;
    }
    
    // Read from the newly adjusted offset
    memset(buffer, 0, sizeof(buffer));
    read(fd, buffer, 6);
    printf("[LSEEK SUCCESS] Shifted offset 5 bytes ahead. Read snippet: \"%s\"\n", buffer);

    // B. Using fcntl() to inspect access flags dynamically
    // F_GETFL retrieves the file status flags
    int flags = fcntl(fd, F_GETFL, 0);
    if (flags < 0) {
        perror("fcntl error");
        close(fd);
        return;
    }

    printf("[FCNTL SUCCESS] Retrieved File Flags. ");
    if ((flags & O_ACCMODE) == O_RDWR) {
        printf("Verification: File is opened in Read-Write (O_RDWR) mode.\n");
    }

    // Clean up
    close(fd);
    unlink(filename); // Delete temporary file
}

int main() {
    printf("=== UNIX Advanced I/O System Calls Demo ===\n");
    
    // Run demonstrations
    demonstrate_directory_calls();
    demonstrate_seek_and_fcntl();
    
    // Run stat demonstration on the current running program source if it exists
    demonstrate_stat_call(".");
    
    return 0;
}
