#include <stdio.h>
#include <stdlib.h>
#include <fcntl.h>
#include <unistd.h>
#include <string.h>

int main()
{
    int fd;
    char filename[] = "sample.txt";
    char write_data[] = "Hello, World!\n";
    char read_buffer[50];
    ssize_t bytes_read;

    /* Create and open file */
    fd = open(filename, O_CREAT | O_WRONLY | O_TRUNC, 0644);

    if (fd < 0)
    {
        perror("Error creating/opening file");
        exit(1);
    }

    printf("File 'sample.txt' created successfully.\n");

    /* Write data */
    if (write(fd, write_data, strlen(write_data)) < 0)
    {
        perror("Error writing to file");
        close(fd);
        exit(1);
    }

    printf("Data written to 'sample.txt'.\n");
    close(fd);

    /* Open file for reading */
    fd = open(filename, O_RDONLY);

    if (fd < 0)
    {
        perror("Error opening file for reading");
        exit(1);
    }

    printf("File 'sample.txt' opened for reading.\n");

    /* Read data */
    bytes_read = read(fd, read_buffer, sizeof(read_buffer) - 1);

    if (bytes_read < 0)
    {
        perror("Error reading file");
        close(fd);
        exit(1);
    }

    read_buffer[bytes_read] = '\0';

    printf("Data read from 'sample.txt':\n%s", read_buffer);

    close(fd);

    /* Delete file */
    if (unlink(filename) < 0)
    {
        perror("Error deleting file");
        exit(1);
    }

    printf("File 'sample.txt' deleted.\n");

    return 0;
}
