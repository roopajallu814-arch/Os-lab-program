#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX_FILES 10
#define MAX_NAME_LEN 20

// Structure to hold directory information
struct Directory {
    char dname[MAX_NAME_LEN];
    char fname[MAX_FILES][MAX_NAME_LEN];
    int fcnt; // File count
};

int main() {
    struct Directory dir;
    int i, ch;
    char temp_file[MAX_NAME_LEN];

    dir.fcnt = 0;
    printf("Enter the name of the root directory: ");
    scanf("%s", dir.dname);

    while (1) {
        printf("\n--- Directory: %s ---\n", dir.dname);
        printf("1. Create File\n");
        printf("2. Delete File\n");
        printf("3. Search File\n");
        printf("4. Display Files\n");
        printf("5. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &ch);

        switch (ch) {
            case 1: // Create File
                if (dir.fcnt >= MAX_FILES) {
                    printf("Error: Directory is full!\n");
                    break;
                }
                printf("Enter the name of the file to create: ");
                scanf("%s", temp_file);

                // Check for duplicate names (Crucial constraint of single-level directories)
                int duplicate = 0;
                for (i = 0; i < dir.fcnt; i++) {
                    if (strcmp(temp_file, dir.fname[i]) == 0) {
                        duplicate = 1;
                        break;
                    }
                }

                if (duplicate) {
                    printf("Error: File '%s' already exists. Duplicate names are not allowed.\n", temp_file);
                } else {
                    strcpy(dir.fname[dir.fcnt], temp_file);
                    dir.fcnt++;
                    printf("File '%s' created successfully.\n", temp_file);
                }
                break;

            case 2: // Delete File
                if (dir.fcnt == 0) {
                    printf("Directory is empty. Nothing to delete.\n");
                    break;
                }
                printf("Enter the name of the file to delete: ");
                scanf("%s", temp_file);

                int found_delete = 0;
                for (i = 0; i < dir.fcnt; i++) {
                    if (strcmp(temp_file, dir.fname[i]) == 0) {
                        printf("File '%s' deleted successfully.\n", temp_file);
                        // Shift remaining files to fill the gap
                        for (int j = i; j < dir.fcnt - 1; j++) {
                            strcpy(dir.fname[j], dir.fname[j + 1]);
                        }
                        dir.fcnt--;
                        found_delete = 1;
                        break;
                    }
                }
                if (!found_delete) {
                    printf("Error: File '%s' not found.\n", temp_file);
                }
                break;

            case 3: // Search File
                if (dir.fcnt == 0) {
                    printf("Directory is empty.\n");
                    break;
                }
                printf("Enter the name of the file to search: ");
                scanf("%s", temp_file);

                int found_search = 0;
                for (i = 0; i < dir.fcnt; i++) {
                    if (strcmp(temp_file, dir.fname[i]) == 0) {
                        printf("File '%s' found at index location %d.\n", temp_file, i + 1);
                        found_search = 1;
                        break;
                    }
                }
                if (!found_search) {
                    printf("File '%s' not found.\n", temp_file);
                }
                break;

            case 4: // Display Files
                if (dir.fcnt == 0) {
                    printf("Directory '%s' is empty.\n", dir.dname);
                } else {
                    printf("Files inside directory '%s':\n", dir.dname);
                    for (i = 0; i < dir.fcnt; i++) {
                        printf("\t -> %s\n", dir.fname[i]);
                    }
                }
                break;

            case 5: // Exit
                printf("Exiting program.\n");
                exit(0);

            default:
                printf("Invalid choice! Please select a valid option.\n");
        }
    }
    return 0;
}
