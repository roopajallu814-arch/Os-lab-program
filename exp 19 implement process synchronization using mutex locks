#include <stdio.h>
#include <stdlib.h>
#include <pthread.h>

long long shared_counter = 0;
pthread_mutex_t lock;

// Thread function
void *increment_counter(void *arg)
{
    int thread_num = *(int *)arg;

    printf("Thread %d started.\n", thread_num);

    for (int i = 0; i < 1000000; i++)
    {
        pthread_mutex_lock(&lock);

        shared_counter++;

        pthread_mutex_unlock(&lock);
    }

    printf("Thread %d finished.\n", thread_num);

    return NULL;
}

int main()
{
    pthread_t thread1, thread2;
    int id1 = 1, id2 = 2;

    printf("===== PROCESS SYNCHRONIZATION USING MUTEX =====\n\n");

    // Initialize mutex
    if (pthread_mutex_init(&lock, NULL) != 0)
    {
        printf("Mutex initialization failed.\n");
        return 1;
    }

    // Create threads
    if (pthread_create(&thread1, NULL, increment_counter, &id1) != 0)
    {
        printf("Error creating Thread 1.\n");
        pthread_mutex_destroy(&lock);
        return 1;
    }

    if (pthread_create(&thread2, NULL, increment_counter, &id2) != 0)
    {
        printf("Error creating Thread 2.\n");
        pthread_join(thread1, NULL);
        pthread_mutex_destroy(&lock);
        return 1;
    }

    // Wait for threads
    pthread_join(thread1, NULL);
    pthread_join(thread2, NULL);

    // Destroy mutex
    pthread_mutex_destroy(&lock);

    printf("\nExpected Counter Value : 2000000\n");
    printf("Actual Counter Value   : %lld\n", shared_counter);

    if (shared_counter == 2000000)
        printf("STATUS : Synchronization Successful.\n");
    else
        printf("STATUS : Race Condition Detected.\n");

    return 0;
}
