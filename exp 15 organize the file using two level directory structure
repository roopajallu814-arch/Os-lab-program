#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX_USERS 5
#define MAX_FILES 10
#define MAX_NAME_LEN 20

// Structure to represent a User File Directory (UFD)
struct UserDirectory {
    char username[MAX_NAME_LEN];
    char filenames[MAX_FILES][MAX_NAME_LEN];
    int file_count;
};

// Structure to represent the Master File Directory (MFD)
struct MasterDirectory {
    struct UserDirectory users[MAX_USERS];
    int user_count;
};

// Helper function to find a user's index in the MFD
int find_user_index(struct MasterDirectory *mfd, char *name) {
    for (int i = 0; i < mfd->user_count; i++) {
        if (strcmp(mfd->users[i].username, name) == 0) {
            return i;
        }
    }
    return -1; // User not found
}

int main() {
    struct MasterDirectory mfd;
    mfd.user_count = 0;

    int choice, user_idx, i, j;
    char uname[MAX_NAME_LEN], fname[MAX_NAME_LEN];

    while (1) {
        printf("\n===== TWO-LEVEL DIRECTORY SYSTEM =====\n");
        printf("1. Add User Directory (Create UFD)\n");
        printf("2. Create File in User Directory\n");
        printf("3. Delete File from User Directory\n");
        printf("4. Search for a File\n");
        printf("5. Display Full Directory Structure\n");
        printf("6. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1: // Add User Directory
                if (mfd.user_count >= MAX_USERS) {
                    printf("Error: Master Directory is full! Cannot add more users.\n");
                    break;
                }
                printf("Enter new username: ");
                scanf("%s", uname);

                if (find_user_index(&mfd, uname) != -1) {
                    printf("Error: User directory '%s' already exists.\n", uname);
                } else {
                    strcpy(mfd.users[mfd.user_count].username, uname);
                    mfd.users[mfd.user_count].file_count = 0;
                    mfd.user_count++;
                    printf("User directory '%s' created successfully.\n", uname);
                }
                break;

            case 2: // Create File
                printf("Enter your username: ");
                scanf("%s", uname);
                user_idx = find_user_index(&mfd, uname);

                if (user_idx == -1) {
                    printf("Error: User directory '%s' does not exist. Create it first.\n", uname);
                    break;
                }

                struct UserDirectory *current_ufd = &mfd.users[user_idx];
                if (current_ufd->file_count >= MAX_FILES) {
                    printf("Error: User directory '%s' is full.\n", uname);
                    break;
                }

                printf("Enter filename to create: ");
                scanf("%s", fname);

                // Check for duplicate names within THIS specific user's directory
                int duplicate = 0;
                for (i = 0; i < current_ufd->file_count; i++) {
                    if (strcmp(current_ufd->filenames[i], fname) == 0) {
                        duplicate = 1;
                        break;
                    }
                }

                if (duplicate) {
                    printf("Error: File '%s' already exists in user '%s's directory.\n", fname, uname);
                } else {
                    strcpy(current_ufd->filenames[current_ufd->file_count], fname);
                    current_ufd->file_count++;
                    printf("File '%s' created successfully under user '%s'.\n", fname, uname);
                }
                break;

            case 3: // Delete File
                printf("Enter username: ");
                scanf("%s", uname);
                user_idx = find_user_index(&mfd, uname);

                if (user_idx == -1) {
                    printf("Error: User directory '%s' not found.\n", uname);
                    break;
                }

                current_ufd = &mfd.users[user_idx];
                printf("Enter filename to delete: ");
                scanf("%s", fname);

                int found_delete = 0;
                for (i = 0; i < current_ufd->file_count; i++) {
                    if (strcmp(current_ufd->filenames[i], fname) == 0) {
                        printf("File '%s' deleted successfully from user '%s'.\n", fname, uname);
                        // Shift remaining files up to fill the gap
                        for (j = i; j < current_ufd->file_count - 1; j++) {
                            strcpy(current_ufd->filenames[j], current_ufd->filenames[j + 1]);
                        }
                        current_ufd->file_count--;
                        found_delete = 1;
                        break;
                    }
                }
                if (!found_delete) {
                    printf("Error: File '%s' not found in user '%s's directory.\n", fname, uname);
                }
                break;

            case 4: // Search File
                printf("Enter filename to search: ");
                scanf("%s", fname);
                
                int total_found = 0;
                // Global search across all user directories
                for (i = 0; i < mfd.user_count; i++) {
                    for (j = 0; j < mfd.users[i].file_count; j++) {
                        if (strcmp(mfd.users[i].filenames[j], fname) == 0) {
                            printf("File found! Path: MFD -> UFD(%s) -> %s\n", mfd.users[i].username, fname);
                            total_found++;
                        }
                    }
                }
                if (total_found == 0) {
                    printf("File '%s' not found anywhere in the system.\n", fname);
                }
                break;

            case 5: // Display Directory Tree
                if (mfd.user_count == 0) {
                    printf("The File System is empty.\n");
                    break;
                }
                printf("\n--- MFD (Master File Directory) ---\n");
                for (i = 0; i < mfd.user_count; i++) {
                    printf(" |-- UFD: %s\n", mfd.users[i].username);
                    if (mfd.users[i].file_count == 0) {
                        printf(" |    └── (Empty)\n");
                    } else {
                        for (j = 0; j < mfd.users[i].file_count; j++) {
                            printf(" |    └── File: %s\n", mfd.users[i].filenames[j]);
                        }
                    }
                }
                break;

            case 6: // Exit
                printf("Exiting Two-Level Directory system.\n");
                exit(0);

            default:
                printf("Invalid option! Please try again.\n");
        }
    }
    return 0;
}
